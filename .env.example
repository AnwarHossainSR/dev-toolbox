# Dev Toolbox - Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# DO NOT COMMIT .env.local to version control

# ============================================================
# SUPABASE CONFIGURATION (Required)
# ============================================================
# Get these from your Supabase project settings:
# https://app.supabase.com -> Project Settings -> API

# Your Supabase project URL
# Format: https://[project-id].supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous public key (safe to expose in browser)
# Found in: Supabase Dashboard > Project Settings > API > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key (KEEP THIS SECRET - Never expose publicly!)
# Only used for server-side operations (tracking, favorites, etc.)
# Found in: Supabase Dashboard > Project Settings > API > service_role (hidden)
# Click "Show" to reveal - handle with care!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================
# NEXT.JS CONFIGURATION
# ============================================================

# Application environment (development | production)
NODE_ENV=development

# Site URL (used for canonical links, redirects, OG tags)
# For localhost development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# For production, use your actual domain:
# NEXT_PUBLIC_SITE_URL=https://devtoolbox.example.com

# ============================================================
# ANALYTICS & MONITORING (Optional)
# ============================================================
# Vercel Analytics is already configured and will work automatically
# These are additional optional configurations:

# Enable debug logging
NEXT_PUBLIC_DEBUG=false

# ============================================================
# FEATURE FLAGS (Optional)
# ============================================================
# Control which features are enabled

# Enable analytics tracking (true | false)
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Enable public/free access to tools without authentication (true | false)
NEXT_PUBLIC_ENABLE_PUBLIC_TOOLS=true

# ============================================================
# HOW TO SET UP
# ============================================================
# 1. Create a Supabase project at https://app.supabase.com
# 2. Copy your API URL and keys from Project Settings > API
# 3. Paste the values above
# 4. Save as .env.local in the project root
# 5. Restart dev server: npm run dev
# 6. For Vercel deployment, add these variables in: Settings > Environment Variables
#    (Do NOT commit .env.local - it's automatically gitignored)

# ============================================================
# SECURITY NOTES
# ============================================================
# ✅ Safe to expose in browser:
#    - NEXT_PUBLIC_SUPABASE_URL
#    - NEXT_PUBLIC_SUPABASE_ANON_KEY
#    - NEXT_PUBLIC_* variables
#
# 🔒 KEEP SECRET - Never expose:
#    - SUPABASE_SERVICE_ROLE_KEY
#    - Any variable without NEXT_PUBLIC_ prefix
#
# Never commit .env.local or .env files to Git!
# Check .gitignore - it should include .env*.local
